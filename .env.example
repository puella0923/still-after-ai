OPENAI_API_KEY=your-api-key-here
EXPO_PUBLIC_OPENAI_API_KEY=your-api-key-here
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Management API (npm run supabase:apply-auth / apply-migration)
# 발급: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=your-access-token

# Kakao OAuth (Supabase Auth — npm run supabase:apply-auth 로 자동 적용)
# Kakao Developers → 내 앱 → REST API 키 / Client Secret
SUPABASE_KAKAO_CLIENT_ID=your-kakao-rest-api-key
SUPABASE_KAKAO_CLIENT_SECRET=your-kakao-client-secret
