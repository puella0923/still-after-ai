{
  "buildCommand": "npx expo export --platform web && node scripts/inject-seo.js",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    { "source": "/((?!$|_expo|assets|favicon\\.ico|favicon\\.png|apple-touch-icon\\.png|favicon-192\\.png|og-image\\.jpg|sitemap\\.xml|robots\\.txt).*)", "destination": "/app.html" }
  ]
}
